[Unit]
Description=FileX — file server with Markdown rendering
After=network.target

[Service]
Type=simple
ExecStart=/home/vuos/code/filex/.venv/bin/python3 /home/vuos/code/filex/serve_md.py --root /home/vuos/code --port 9090 --bind 0.0.0.0
Restart=always
RestartSec=5
WorkingDirectory=/home/vuos/code/filex

[Install]
WantedBy=default.target
